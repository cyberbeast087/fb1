{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/captures", "dest": "/api/admin.php" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "environment": {
    "ADMIN_PASS": "admin123"
  }
}
